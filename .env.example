# 数据库
# PostgreSQL 连接字符串，格式：postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME

# 微信扫码登录（通过 starter.jue.sh 平台接入）
# 微信登录平台的基础地址，默认使用 starter.jue.sh
WECHAT_LOGIN_PROVIDER_BASE_URL=https://starter.jue.sh

# 在 starter.jue.sh 应用管理页创建应用后获得的客户端 ID，格式如 wcid_xxx
WECHAT_LOGIN_CLIENT_ID=your_client_id

# 对应 CLIENT_ID 的客户端密钥，格式如 wcs_xxx，仅用于服务端
WECHAT_LOGIN_CLIENT_SECRET=your_client_secret

# 在平台登记的 OAuth 回调地址，必须与登记值完全一致（协议/域名/端口/路径/斜杠）
WECHAT_LOGIN_REDIRECT_URI=http://localhost:3000/auth/wechat/callback

# 用于签名和校验 OAuth state 的随机密钥，建议至少 32 字节，防止 CSRF 攻击
WECHAT_LOGIN_STATE_SECRET=your_random_state_secret
